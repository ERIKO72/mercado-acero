{
  "expo": {
    "name": "Marketplace del Acero",
    "slug": "marketplace-acero",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "marketplaceacero",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C0392B"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "android": {
      "package": "com.eimahr.marketplaceacero",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD55Qk5pry9baZ0WkRJOrX9VZx1DGHRGYU"
        }
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Marketplace del Acero necesita tu ubicación para mostrarte las tiendas más cercanas."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f59e2ae0-0c2d-4fc9-a52a-989b8593cd89"
      }
    },
    "owner": "eriko72"
  }
}
