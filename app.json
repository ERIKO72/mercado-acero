{
  "expo": {
    "name": "Marketplace del Acero",
    "slug": "marketplace-acero",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "marketplaceacero",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B0F2A"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "waze"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#6B0F2A",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.armanditomh.marketplaceacero",
      "versionCode": 4,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD55Qk5pry9baZ0WkRJOrX9VZx1DGHRGYU"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#C0392B",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Marketplace del Acero necesita tu ubicación para mostrarte las tiendas más cercanas."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "69397dc2-fe9c-4648-84ce-07f4c5029786"
      }
    },
    "owner": "armanditomh",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/69397dc2-fe9c-4648-84ce-07f4c5029786"
    },
    "ios": {}
  }
}
